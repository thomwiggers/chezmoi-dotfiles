{{- $isDebian := false -}}
{{- $isArch := false -}}
{{- if eq .chezmoi.os "linux" -}}
{{-   $isDebian = or (eq .chezmoi.osRelease.id "debian") (eq .chezmoi.osRelease.id "ubuntu") (contains "debian" (index .chezmoi.osRelease "idLike" | default "")) -}}
{{-   $isArch = or (eq .chezmoi.osRelease.id "arch") (contains "arch" (index .chezmoi.osRelease "idLike" | default "")) -}}
{{- end -}}
{{- if or $isDebian $isArch -}}
#!/bin/bash
set -euo pipefail

{{ if $isDebian -}}
# Install apt packages
sudo apt-get update -qq
sudo apt-get install -y \
    bat \
    git \
    ripgrep \
    tmux \
    wget \
    xz-utils \
    zsh \
    zsh-syntax-highlighting \
    zstd

# bat is installed as 'batcat' on some Ubuntu/Debian versions; normalise it
if ! command -v bat &>/dev/null && command -v batcat &>/dev/null; then
    mkdir -p "$HOME/.local/bin"
    ln -sf "$(command -v batcat)" "$HOME/.local/bin/bat"
fi

# dust (du replacement) — not in apt
if ! command -v dust &>/dev/null; then
    DUST_VERSION=$(curl -fsSL https://api.github.com/repos/bootandy/dust/releases/latest | grep '"tag_name"' | sed 's/.*"v\([^"]*\)".*/\1/')
    curl -fsSL "https://github.com/bootandy/dust/releases/latest/download/dust-v${DUST_VERSION}-x86_64-unknown-linux-musl.tar.gz" \
        | tar -xz --strip-components=1 -C "$HOME/.local/bin" "dust-v${DUST_VERSION}-x86_64-unknown-linux-musl/dust"
fi

# git-delta — not in apt
if ! command -v delta &>/dev/null; then
    DELTA_VERSION=$(curl -fsSL https://api.github.com/repos/dandavison/delta/releases/latest | grep '"tag_name"' | sed 's/.*"\([^"]*\)".*/\1/')
    curl -fsSL "https://github.com/dandavison/delta/releases/latest/download/delta-${DELTA_VERSION}-x86_64-unknown-linux-musl.tar.gz" \
        | tar -xz --strip-components=1 -C "$HOME/.local/bin" "delta-${DELTA_VERSION}-x86_64-unknown-linux-musl/delta"
fi

# vivid (LS_COLORS generator) — not in apt
if ! command -v vivid &>/dev/null; then
    VIVID_VERSION=$(curl -fsSL https://api.github.com/repos/sharkdp/vivid/releases/latest | grep '"tag_name"' | sed 's/.*"v\([^"]*\)".*/\1/')
    curl -fsSL "https://github.com/sharkdp/vivid/releases/latest/download/vivid-v${VIVID_VERSION}-x86_64-unknown-linux-musl.tar.gz" \
        | tar -xz --strip-components=1 -C "$HOME/.local/bin" "vivid-v${VIVID_VERSION}-x86_64-unknown-linux-musl/vivid"
fi

# starship prompt
if ! command -v starship &>/dev/null; then
    curl -fsSL https://starship.rs/install.sh | sh -s -- --yes --bin-dir "$HOME/.local/bin"
fi

# uv (Python package manager)
if ! command -v uv &>/dev/null; then
    curl -LsSf https://astral.sh/uv/install.sh | sh
fi

{{ else if $isArch -}}
# Install pacman packages (all available in official repos)
sudo pacman -Syu --noconfirm --needed \
    bat \
    git \
    git-delta \
    dust \
    ripgrep \
    starship \
    tmux \
    uv \
    vivid \
    wget \
    xz \
    zsh \
    zsh-syntax-highlighting \
    zstd

{{ end -}}
{{ end -}}
