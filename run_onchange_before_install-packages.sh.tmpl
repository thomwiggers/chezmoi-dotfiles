{{- $isDebian := false -}}
{{- $isArch := false -}}
{{- $isAmazonLinux := false -}}
{{- if eq .chezmoi.os "linux" -}}
{{-   $isDebian = or (eq .chezmoi.osRelease.id "debian") (eq .chezmoi.osRelease.id "ubuntu") (contains "debian" (index .chezmoi.osRelease "idLike" | default "")) -}}
{{-   $isArch = or (eq .chezmoi.osRelease.id "arch") (contains "arch" (index .chezmoi.osRelease "idLike" | default "")) -}}
{{-   $isAmazonLinux = and (eq .chezmoi.osRelease.id "amzn") (contains "2023" (index .chezmoi.osRelease "versionID" | default "")) -}}
{{- end -}}
{{- $useBrew := or (eq .chezmoi.os "darwin") $isDebian $isAmazonLinux -}}
{{- if or $useBrew $isArch -}}
#!/bin/bash
set -euo pipefail

{{ if $isDebian -}}
# Homebrew prerequisites (Debian/Ubuntu)
sudo apt-get update -qq
sudo apt-get install -y build-essential procps curl file git

{{ else if $isArch -}}
# Arch: all packages available in official repos
sudo pacman -Syu --noconfirm --needed \
    bat \
    git \
    git-delta \
    dust \
    ripgrep \
    starship \
    tmux \
    uv \
    vivid \
    wget \
    xz \
    zsh \
    zsh-syntax-highlighting \
    zstd

{{ else if $isAmazonLinux -}}
# Homebrew prerequisites (Amazon Linux 2023)
sudo dnf groupinstall -y "Development Tools"
sudo dnf install -y curl file git procps-ng

{{ end -}}
{{ if and (eq .chezmoi.os "linux") $useBrew -}}
# Install Homebrew
if ! command -v brew &>/dev/null; then
    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# Add brew to PATH for this script session
if [ -f /home/linuxbrew/.linuxbrew/bin/brew ]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
elif [ -f "$HOME/.linuxbrew/bin/brew" ]; then
    eval "$("$HOME/.linuxbrew/bin/brew" shellenv)"
fi

{{ end -}}
{{ if $useBrew -}}
brew bundle --file=/dev/stdin <<'BREWFILE'
brew "bat"
brew "dust"
brew "git"
brew "git-delta"
{{ if eq .chezmoi.os "darwin" -}}
brew "gnu-sed"
brew "gnu-tar"
brew "neovim"
brew "python"
{{ end -}}
brew "ripgrep"
brew "starship"
brew "tmux"
brew "uv"
brew "vivid"
brew "wget"
brew "xz"
brew "zsh"
{{ if eq .chezmoi.os "darwin" -}}
brew "zsh-completions"
{{ end -}}
brew "zsh-syntax-highlighting"
brew "zstd"
BREWFILE
{{ end -}}
{{ end -}}
