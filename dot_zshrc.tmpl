
# Settings
setopt AUTOCD            # cd into a directory by typing its name without 'cd'
setopt AUTO_PUSHD	 # make cd push to directory stack
setopt EXTENDED_GLOB     # enable extended globbing patterns (e.g. ^foo, **/, #)
setopt NO_BG_NICE        # don't lower priority of background jobs
setopt NO_HUP            # don't kill background jobs when the shell exits
setopt NO_LIST_BEEP      # don't beep on ambiguous completions
setopt NO_HIST_BEEP      # don't beep when navigating past history bounds
setopt NO_BEEP           # disable all beeping globally
setopt LOCAL_OPTIONS     # options set inside a function are restored on return
setopt LOCAL_TRAPS       # traps set inside a function are restored on return
setopt HIST_VERIFY       # show history expansion before executing (don't run immediately)
setopt SHARE_HISTORY     # share history across all active shell sessions in real time
setopt PROMPT_SUBST      # enable parameter{{ .chezmoi.pathSeparator }}command substitution in prompt strings
setopt CORRECT           # suggest corrections for mistyped commands
setopt COMPLETE_IN_WORD  # allow tab completion from anywhere within a word, not just the end
setopt HIST_IGNORE_ALL_DUPS  # remove all older duplicates when a command is added to history
setopt HIST_REDUCE_BLANKS    # strip superfluous whitespace from history entries
setopt MULTIBYTE         # enable multibyte character support (e.g. UTF-8)
setopt COMBINING_CHARS   # treat combining characters (e.g. diacritics) as part of the base character
setopt COMPLETE_ALIASES  # treat aliases as distinct commands for completion purposes

# HISTORY
HISTSIZE=10000          # number of commands kept in memory for the current session
SAVEHIST=10000          # number of commands written to the history file on disk
setopt appendhistory    # append to the history file instead of overwriting it on exit


autoload -Uz compinit
zstyle ':completion:*' menu select

{{ $ls := "ls" }}
{{- if eq .chezmoi.os "darwin" -}}
{{ $ls = "gls" }}
{{- end -}}

alias ls='{{ $ls }} -h --color=auto'
alias ll='ls -l'
alias la='ls -a'
alias l='ls'
alias sl='ls'

alias gdb='gdb -q'
alias gp='gp -q'
alias grep='grep --color=auto'
alias diff='diff --color=auto'
alias cat=bat

source ~/.zsh/key-bindings.zsh

{{- if eq .chezmoi.os "darwin" }}
if [ -e /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]; then
    source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
fi
{{- end -}}

eval "$(starship init zsh)"

# Initialize completion
# only load fresh once a day
if [ "$(date +'%j')" != "$(stat -f '%Sm' -t '%j' ~/.zcompdump 2>/dev/null)" ]; then
    compinit
else
    compinit -C
fi

export LS_COLORS="$(vivid generate molokai)"

